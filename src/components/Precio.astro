---
---
<section class="py-20 px-4 bg-dark-card/50">
  <div class="max-w-4xl mx-auto">
    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Inversión</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-3 mb-4">Precio del curso</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">Una inversión en tu carrera profesional.</p>
    </div>

    <!-- Pricing Card -->
    <div class="max-w-lg mx-auto">
      <div class="card-tech rounded-3xl p-8 sm:p-10 text-center relative overflow-hidden">
        <!-- Badge -->
        <div class="absolute top-0 right-0 bg-primary text-white text-xs font-bold px-4 py-2 rounded-bl-xl">
          CUPOS LIMITADOS
        </div>

        <!-- Precio -->
        <div class="mb-8">
          <p class="text-gray-400 text-lg mb-2">Precio por persona</p>
          <div class="flex items-baseline justify-center gap-1">
            <span class="text-gray-500 text-2xl">$</span>
            <span class="text-6xl sm:text-7xl font-extrabold gradient-text">50.000</span>
          </div>
          <p class="text-gray-500 mt-2">CLP por persona</p>
        </div>

        <!-- Qué incluye -->
        <div class="space-y-4 mb-10 text-left">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-gray-300">2 días de curso intensivo (sábado y domingo)</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-gray-300">Grupos reducidos (máximo 10 personas)</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-gray-300">Generarás y desplegarás proyectos reales en internet</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-gray-300">Te llevarás tu portafolio con proyectos propios</span>
          </div>
        </div>

        <!-- CTA -->
        <a
          href="https://wa.me/56920506678?text=Hola%2C%20quiero%20inscribirme%20al%20curso%20de%20Desarrollo%20con%20IA%20%C2%BFDisponibilidad%3F"
          target="_blank"
          rel="noopener noreferrer"
          class="whatsapp-btn block w-full py-4 rounded-xl text-white font-bold text-lg shadow-lg text-center"
        >
          Inscribirse por WhatsApp
        </a>

        <p class="text-gray-500 text-sm mt-4">Preguntá por disponibilidad y fechas</p>
      </div>
    </div>

    <!-- Métodos de pago -->
    <div class="mt-12 text-center">
      <p class="text-gray-400 mb-4">Métodos de pago aceptados:</p>
      <div class="flex flex-wrap justify-center gap-6 text-gray-500">
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
          Transferencia bancaria
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          Efectivo
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          MercadoPago (a confirmar)
        </span>
      </div>
    </div>
  </div>
</section>
