---
---
<section class="py-20 px-4">
  <div class="max-w-4xl mx-auto">
    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Tu instructor</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-3 mb-4">¿Quién imparte el curso?</h2>
    </div>

    <!-- Card del instructor -->
    <div class="card-tech rounded-3xl p-8 sm:p-10">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8">
        <!-- Avatar placeholder -->
        <div class="w-32 h-32 rounded-2xl bg-gradient-to-br from-primary to-accent flex items-center justify-center shrink-0">
          <span class="text-4xl font-bold text-white">L</span>
        </div>

        <!-- Info -->
        <div class="text-center sm:text-left">
          <h3 class="text-2xl font-bold text-white mb-1">lanedu.cl</h3>
          <p class="text-primary font-medium mb-4">Plataforma de Educación en Tecnología</p>
          <p class="text-gray-400 leading-relaxed mb-6">
            En <span class="text-white font-semibold">lanedu.cl</span> nos especializamos en formar desarrolladores en las tecnologías más nuevas del mercado. Con un enfoque práctico y directo, enseñamos a nuestros alumnos a utilizar herramientas de vanguardia como la inteligencia artificial para crear software real.
          </p>

          <!-- Habilidades -->
          <div class="flex flex-wrap justify-center sm:justify-start gap-2">
            <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium">Inteligencia Artificial</span>
            <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium">Desarrollo de Software</span>
            <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium">Agentes IA</span>
            <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium">OpenCode</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
