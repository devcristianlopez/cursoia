---
---
<section class="py-20 px-4 bg-dark-card/50">
  <div class="max-w-4xl mx-auto">
    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Ubicación</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-3 mb-4">¿Dónde se imparte?</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">Curso presencial en la hermosa ciudad de Valparaíso.</p>
    </div>

    <!-- Mapa y info -->
    <div class="card-tech rounded-3xl overflow-hidden">
      <!-- Mapa placeholder -->
      <div class="w-full h-64 sm:h-80 bg-dark relative flex items-center justify-center">
        <div class="text-center">
          <svg class="w-16 h-16 text-primary/30 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <p class="text-gray-500 text-lg font-medium">Valparaíso, Chile</p>
          <p class="text-gray-600 text-sm mt-1">Dirección exacta por confirmar</p>
        </div>

        <!-- Línea decorativa -->
        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-primary via-accent to-primary"></div>
      </div>

      <!-- Info -->
      <div class="p-6 sm:p-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <h3 class="text-white font-semibold mb-2 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Dirección
            </h3>
            <p class="text-gray-400">Por confirmar — centro de Valparaíso</p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-2 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Cómo llegar
            </h3>
            <p class="text-gray-400">Cerca de estaciones de metro y buses</p>
          </div>
        </div>

        <!-- Nota -->
        <div class="mt-6 p-4 rounded-xl bg-primary/5 border border-primary/20">
          <p class="text-gray-400 text-sm flex items-start gap-2">
            <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>La dirección exacta se confirmará una vez que reserves tu lugar. Trabajamos en un espacio cómodo y equipado para el curso.</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
