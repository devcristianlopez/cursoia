---
const modulos = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>`,
    titulo: "Fundamentos de IA",
    descripcion: "Entiende cómo funcionan los modelos de lenguaje y cómo aplicarlos al desarrollo de software real."
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>`,
    titulo: "OpenCode y Herramientas",
    descripcion: "Configura tu entorno de desarrollo con OpenCode, terminales y las mejores extensiones para trabajar con IA."
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`,
    titulo: "Agentes Autónomos",
    descripcion: "Aprende a crear y configurar agentes de IA que planifican, ejecutan y revisan código de forma autónoma."
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>`,
    titulo: "Flujos Agentic",
    descripcion: "Domina los flujos de trabajo agentic: planificación, ejecución, iteración y revisión de código."
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>`,
    titulo: "Casos con Lemoria",
    descripcion: "Aplica todo lo aprendido en proyectos reales utilizando la plataforma Lemoria como caso de estudio."
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>`,
    titulo: "Buenas Prácticas",
    descripcion: "Seguridad, testing, documentación y mejores prácticas para desarrollar software con IA de forma responsable."
  }
];
---

<section class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Programa del curso</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-3 mb-4">¿Qué aprenderás?</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">Un programa práctico y directo para que domines el desarrollo de software con agentes de IA.</p>
    </div>

    <!-- Grid de módulos -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {modulos.map((modulo, i) => (
        <div class="card-tech rounded-2xl p-6 group">
          <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-4 group-hover:bg-primary/20 transition-colors">
            <Fragment set:html={modulo.icon} />
          </div>
          <h3 class="text-xl font-bold text-white mb-2">{modulo.titulo}</h3>
          <p class="text-gray-400 leading-relaxed">{modulo.descripcion}</p>
        </div>
      ))}
    </div>
  </div>
</section>
